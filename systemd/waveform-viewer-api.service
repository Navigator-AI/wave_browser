[Unit]
Description=Wave Browser Backend API
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=wavebrowser
WorkingDirectory=/projects/sujayak/wave_browser/backend
Environment="PATH=/projects/sujayak/wave_browser/backend/venv/bin"
ExecStart=/projects/sujayak/wave_browser/backend/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8802
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
